# Platform Operations Dashboard — configuration
# Copy to .env and fill in values:  cp .env.example .env

# ─────────────────────────────────────────────────────────────
# DEMO MODE
# Set to true to run the full dashboard with realistic mock data and
# NO external systems or credentials. Great for a local walkthrough.
# Leave false (default) to connect to live OCP / Jira / Grafana.
# ─────────────────────────────────────────────────────────────
DEMO_MODE=true

# Server
APP_HOST=0.0.0.0
APP_PORT=9100
DEBUG=false

# PostgreSQL — optional. Leave blank to fall back to JSON files under data/.
DATABASE_URL=

# Redis — optional. Leave blank to fall back to an in-memory TTL cache.
REDIS_URL=

# ── Jira (issue tracking tab) ──
JIRA_BASE_URL=https://jira.example.com
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECTS=DEVOPS,EAAS,CLOUD

# ── Grafana (user-login tracking tab) ──
GRAFANA_BASE_URL=https://grafana.example.com
GRAFANA_API_KEY=
GRAFANA_DASHBOARD_UIDS=

# Grafana stats fallback for MCP usage (only if OCP not configured)
GRAFANA_STATS_URL=
GRAFANA_STATS_USER=readonly
GRAFANA_STATS_PASSWORD=readonly

# ── OpenShift / Kubernetes (pod health + MCP usage from pod logs) ──
# Option A: static bearer token (expires, must be refreshed manually)
#   OCP_TOKEN=sha256~xxxxx
# Option B (recommended): service-account auto-refresh
#   Set OCP_SA_USER + OCP_SA_PASSWORD and leave OCP_TOKEN empty.
OCP_API_URL=https://console-openshift-console.apps.ocp-cluster.example.com/api/kubernetes
OCP_TOKEN=
OCP_SA_USER=svc-monitoring
OCP_SA_PASSWORD=
OCP_TOKEN_REFRESH_HOURS=12
OCP_MCP_TOOLS=nexus,bitbucket,artifactory,jenkins,ocp,eaas

# Legacy HTTP MCP health probes (optional)
MCP_SERVERS=
MCP_POLL_INTERVAL_SECONDS=300

# ── ChatOps analytics (optional, separate cluster) ──
OCP_CHATOPS_API_URL=https://console-openshift-console.apps.analytics-cluster.example.com/api/kubernetes
OCP_CHATOPS_TOKEN=
OCP_CHATOPS_NAMESPACE=chatops-analytics
OCP_CHATOPS_SA_USER=
OCP_CHATOPS_SA_PASSWORD=

# Deployment target for deploy.sh
DEPLOY_HOST=dashboard-host.example.com

# ── Pod-health email alerts ──
ALERT_ENABLED=true
ALERT_SMTP_HOST=smtp.example.com
ALERT_SMTP_PORT=25
ALERT_FROM=platform-dashboard@example.com
# Default recipients (semicolon-separated) when no tool-specific owner is set
ALERT_DEFAULT_TO=
# CC on all alerts (semicolon-separated)
ALERT_CC=
# Per-tool owners:  tool:email1;email2,tool2:email3
# Example: nexus:alice@example.com,jenkins:carol@example.com
ALERT_OWNERS=
ALERT_COOLDOWN_HOURS=6
